# ===========================================
# Environment Variables Template
# Скопируйте этот файл как .env.local или .env.dev/test/acceptance
# и заполните реальными значениями
# ===========================================

# === NODE_ENV ===
NODE_ENV=development

# === LOCAL POSTGRES (для Docker) ===
# DATABASE_URL для каждого контура своя:
# dev: horizon_dev, test: horizon_test, acceptance: horizon_acceptance
POSTGRES_PASSWORD=your_password_here
POSTGRES_USER=horizon
POSTGRES_URL=postgresql://horizon:your_password@192.168.122.3:5432/horizon_dev
POSTGRES_URL_NON_POOLING=postgresql://horizon:your_password@192.168.122.3:5432/horizon_dev
DATABASE_URL=postgresql://horizon:your_password@192.168.122.3:5432/horizon_dev
POSTGRES_HOST=192.168.122.3

# === LOCAL REDIS (Docker container с auth) ===
# Формат: redis://:password@hostname:port
REDIS_TOKEN=your_redis_password
REDIS_URL=redis://:your_redis_password@horizon-redis:6379

# === Z.AI ===
ZAI_USER_ID=your_z_ai_user_id
ZAI_TOKEN=your_z_ai_token
ZAI_CHAT_ID=your_z_ai_chat_id
ZAI_BASE_URL=http://172.25.136.193:8080/v1
ZAI_API_KEY=Z.ai

# === OPENROUTER ===
OPENROUTER_API_KEY=your_openrouter_key

# === MOEX JWT ===
MOEX_JWT=your_moex_jwt

# === T-Invest API ===
TINVEST_TOKEN=your_tinvest_token

# === VERCEL (только для CI/CD) ===
# VERCEL_TOKEN=
# VERCEL_PROJECT_ID=
# VERCEL_ORG_ID=

# === CRON ===
CRON_SECRET=your_cron_secret_here